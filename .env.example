# ── Sitemap ────────────────────────────────────────────────
# Replace with your actual domain
NEXT_PUBLIC_SITE_URL=https://upendrapublicity.com

# ── Contact Info (displayed on site) ──────────────────────
NEXT_PUBLIC_WHATSAPP_PHONE=91XXXXXXXXXX
NEXT_PUBLIC_PHONE_NUMBER=+91-XXXX-XXXXXX
NEXT_PUBLIC_EMAIL=info@upendrapublicity.com

# ── Email (SMTP) ───────────────────────────────────────────
# Gmail: use App Password (not your main password)
# Settings > Security > 2FA ON > App Passwords > generate one
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youraddress@gmail.com
SMTP_PASS=your-16-char-app-password
ADMIN_EMAIL=youraddress@gmail.com

# ── Database ───────────────────────────────────────────────
# Local (SQLite — zero setup):
DATABASE_URL="file:./dev.db"
# Production (PostgreSQL):
# DATABASE_URL="postgresql://user:password@host:5432/upendra_db?schema=public"
